#include <stdio.h>



int main() {
    int n;
    printf("input: ");
    scanf("%d", &n);

    if (n < 2) {
        printf("횕챨챤챰챵청천 첨챔챰책챘 챠책챵\n");
        return 0;
    }

    int P[n];   // 챙횪챰챰챔창 채챘첼 첨챔챰책챘
    int i, p;

    // 횉횪챦챤챘챠첼책챙 챙횪챰챰챔창 첨챔챰챘횪챙챔 챤챵 2 채챤 n
    for (i = 0; i < n; i++) {
        P[i] = i + 1;
    }
    P[0] = 0; // 1 챠책 첼창챘첼책챵챰첼 챦챨챤챰챵청챙

    // 횖책첩책챵챤 횦챨횪챵챤챰척책챠횪
    for (p = 2; p * p <= n; p++) {
        if (P[p - 1] != 0) {  // 책챰챘챔 첨챔챰챘챤 챠책 창청첨책챨챗챠처챵챤
            for (i = p * p; i <= n; i += p) {
                P[i - 1] = 0; // 창청첨책챨챗챔창횪책챙 챰챤챰챵횪창챠청책
            }
        }
    }

    // 횙채횪챘첼책챙 챠처챘챔: 챦책챨책챠챤챰챔챙 챦챨챤챰챵청책 첨챔챰챘횪 창 챠횪첨횪챘챤 챙횪챰챰챔창횪
    int k = 0;
    for (i = 0; i < n; i++) {
        if (P[i] != 0) {
            P[k++] = P[i];
        }
    }

    // 횂청창챤채 챦챨챤챰챵청천 첨챔챰책챘
    for (i = 0; i < k; i++) {
        printf("%d ", P[i]);
    }
    printf("\n");

    return 0;
}
