#include <stdio.h>
#include <locale.h>>

int main() {
    int n, i, j, temp;
    setlocale(LC_ALL, "");
    printf("횂창책채챔챵책 챗챤챘챔첨책챰챵창챤 첵챘책챙책챠챵챤창 챙횪챰챰챔창횪: ");
    scanf("%d", &n);

    int a[n];

    printf("횂창책채챔챵책 첵챘책챙책챠챵청 챙횪챰챰챔창횪:\n");
    for (i = 0; i < n; i++) {
        scanf("%d", &a[i]);
    }

    printf("\n횑횪챰챰챔창: ");
    for (i = 0; i < n; i++) {
        printf("%d ", a[i]);
    }

    int max = a[0];
    int min = a[0];
    int sum = 0;

    for (i = 0; i < n; i++) {
        if (a[i] > max) {
            max = a[i];
        }
        if (a[i] < min) {
            min = a[i];
        }
        sum += a[i];
    }

    for (i = 0; i < n - 1; i++) {
        for (j = 0; j < n - i - 1; j++) {
            if (a[j] > a[j + 1]) {
                temp = a[j];
                a[j] = a[j + 1];
                a[j + 1] = temp;
            }
        }
    }

    printf("\n횑횪챗챰챔챙횪챘체챠청챕 첵챘책챙책챠챵: %d", max);
    printf("\n횑챔챠챔챙횪챘체챠청챕 첵챘책챙책챠챵: %d", min);
    printf("\n횗처챙챙횪 첵챘책챙책챠챵챤창: %d", sum);

    printf("\n횓챵챰챤챨챵챔챨챤창횪챠챠청챕 챙횪챰챰챔창: ");
    for (i = 0; i < n; i++) {
        printf("%d ", a[i]);
    }

    return 0;
}
