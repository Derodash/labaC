#include <stdio.h>
#include <locale.h>

int main() {
    int arr[100];
    int n = 0;
    int choice;
    int i;
    setlocale(LC_ALL, "");

    do {
        printf("\n--- 횑횇횒횧 ---\n");
        printf("1. 횂창책챰챵챔 챙횪챰챰챔창\n");
        printf("2. 횕챤챗횪챌횪챵체 챙횪챰챰챔창\n");
        printf("3. 횒횪챕챵챔 챙챔챠챔챙처챙 챔 챙횪챗챰챔챙처챙\n");
        printf("4. 횒횪챕챵챔 챰챨책채챠책책\n");
        printf("5. 횒횪챕챵챔 첵챘책챙책챠챵\n");
        printf("6. 횕책챨책창책챨챠처챵체 챙횪챰챰챔창\n");
        printf("0. 횂청천챤채\n");
        printf("횂청찼챤챨: ");
        scanf("%d", &choice);

        if (choice == 1) {
            printf("횂창책채챔챵책 챗챤챘챔첨책챰챵창챤 첵챘책챙책챠챵챤창: ");
            scanf("%d", &n);

            if (n <= 0 || n > 100) {
                printf("횓첩챔찼챗횪!\n");
                n = 0;
                continue;
            }

            printf("횂창책채챔챵책 첵챘책챙책챠챵청:\n");
            for ( i = 0; i < n; i++) {
                scanf("%d", &arr[i]);
            }
        }

        else if (choice == 2) {
            if (n == 0) {
                printf("횑횪챰챰챔창 챦처챰챵!\n");
                continue;
            }

            printf("횑횪챰챰챔창: ");
            for (i = 0; i < n; i++) {
                printf("%d ", arr[i]);
            }
            printf("\n");
        }

        else if (choice == 3) {
            if (n == 0) {
                printf("횗챠횪첨횪챘횪 창창책채챔챵책 챙횪챰챰챔창!\n");
                continue;
            }

            int min = arr[0], max = arr[0];

            for (i = 1; i < n; i++) {
                if (arr[i] < min) min = arr[i];
                if (arr[i] > max) max = arr[i];
            }

            printf("횑챔챠챔챙처챙: %d\n", min);
            printf("횑횪챗챰챔챙처챙: %d\n", max);
        }

        else if (choice == 4) {
            if (n == 0) {
                printf("횗챠횪첨횪챘횪 창창책채챔챵책 챙횪챰챰챔창!\n");
                continue;
            }

            int sum = 0;
            for ( i = 0; i < n; i++) {
                sum += arr[i];
            }

            printf("횗챨책채챠책책: %.2f\n", (float)sum / n);
        }

        else if (choice == 5) {
            if (n == 0) {
                printf("횗챠횪첨횪챘횪 창창책채챔챵책 챙횪챰챰챔창!\n");
                continue;
            }

            int x, found = 0;
            printf("횂창책채챔챵책 첨챔챰챘챤 채챘첼 챦챤챔챰챗횪: ");
            scanf("%d", &x);

            for ( i = 0; i < n; i++) {
                if (arr[i] == x) {
                    printf("횒횪챕채책챠챤 챠횪 챦챤챌챔철챔챔 %d\n", i);
                    found = 1;
                }
            }

            if (!found) {
                printf("횒책 챠횪챕채책챠챤\n");
            }
        }

        else if (choice == 6) {
            if (n == 0) {
                printf("횗챠횪첨횪챘횪 창창책채챔챵책 챙횪챰챰챔창!\n");
                continue;
            }

            for (i = 0; i < n / 2; i++) {
                int temp = arr[i];
                arr[i] = arr[n - 1 - i];
                arr[n - 1 - i] = temp;
            }

            printf("횑횪챰챰챔창 챦책챨책창쨍챨챠처챵\n");
        }

    } while (choice != 0);

    return 0;
}
