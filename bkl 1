#include <stdio.h>
#include <ctype.h>
#include <locale.h>
// 척처챠챗철챔첼 채챘첼 챦챨챤창책챨챗챔 찾챘횪챰챠청천
int isvowel(int c) {
    c = tolower(c);
    return (c=='a' || c=='e' || c=='i' || c=='o' || c=='u' || c=='y');
}

int main() {
    setlocale(LC_ALL, "Rus");
    char filename[100];
    FILE *f;
    int c;

    int total = 0;
    int lines = 0;
    int digits = 0;
    int punct = 0;
    int spaces = 0;
    int letters = 0;
    int lower = 0;
    int upper = 0;
    int vowels = 0;
    int consonants = 0;

    // 창창챤채 챔챙책챠챔 척횪챕챘횪
    printf("횂창책채챔챵책 챔챙첼 척횪챕챘횪: ");
    scanf("%s", filename);

    // 챤챵챗챨청챵챔책 척횪챕챘횪
    f = fopen(filename, "r");
    if (f == NULL) {
        printf("횓첩챔찼챗횪 챤챵챗챨청챵챔첼 척횪챕챘횪\n");
        return 1;
    }

    // 첨챵책챠챔책 척횪챕챘횪 챦챤챰챔챙창챤챘체챠챤
    while ((c = fgetc(f)) != EOF) {
        total++;

        if (c == '\n')
            lines++;

        if (isdigit(c))
            digits++;

        if (ispunct(c))
            punct++;

        if (isspace(c))
            spaces++;

        if (isalpha(c)) {
            letters++;

            if (islower(c))
                lower++;

            if (isupper(c))
                upper++;

            if (isvowel(c))
                vowels++;
            else
                consonants++;
        }
    }

    fclose(f);

    // 창청창챤채 챨책챌처챘체챵횪챵횪
    printf("횂챰책찾챤 챰챔챙창챤챘챤창: %d\n", total);
    printf("횗챵챨챤챗: %d\n", lines);
    printf("횜챔척챨: %d\n", digits);
    printf("횉챠횪챗챤창 챦챨책챦챔챠횪챠챔첼: %d\n", punct);
    printf("횕챨챤찼책챘체챠청천 챰챔챙창챤챘챤창: %d\n", spaces);
    printf("횁처챗창: %d\n", letters);
    printf("횗챵챨챤첨챠청천: %d\n", lower);
    printf("횕챨챤챦챔챰챠청천: %d\n", upper);
    printf("횄챘횪챰챠청천: %d\n", vowels);
    printf("횗챤찾챘횪챰챠청천: %d\n", consonants);

    return 0;
}
