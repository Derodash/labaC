#include <stdio.h>

int main() {
    int n;
    int i, j;
    int isPrime;
    int count = 0;
    int sum = 0;

    printf("Vvedite chislo n: ");
    scanf("%d", &n);

    for(i = 2; i <= n; i++) {
        isPrime = 1;

        for(j = 2; j < i; j++) {
            if(i % j == 0) {
                isPrime = 0;
                break;
            }
        }

        if(isPrime == 1) {
            printf("%d ", i);
            count = count + 1;
            sum = sum + i;
        }
    }

    printf("\nKolichestvo prostyh chisel: %d\n", count);
    printf("Summa prostyh chisel: %d\n", sum);

    return 0;
}
