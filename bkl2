#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

#define LIMIT_WORDS 100000
#define LIMIT_LEN 256

typedef struct {
    char *text;
    int freq;
} Entry;

/* ----------- Прототипы ----------- */
char *read_token(FILE *fp);
int search_word(Entry **dict, int size, const char *word);
void insert_word(Entry **dict, int *size, const char *word);
int sort_alpha(const void *a, const void *b);
int sort_freq(const void *a, const void *b);

/* ----------- MAIN ----------- */
int main(int argc, char *argv[])
{
    if (argc < 2) {
        printf("Usage: %s <files>\n", argv[0]);
        return 1;
    }

    Entry *dictionary[LIMIT_WORDS];
    int word_count = 0;

    for (int i = 1; i < argc; i++) {
        FILE *file = fopen(argv[i], "r");
        if (!file) {
            printf("Error opening %s\n", argv[i]);
            continue;
        }

        printf("Reading: %s\n", argv[i]);

        char *token;
        while ((token = read_token(file)) != NULL) {
            int pos = search_word(dictionary, word_count, token);
            if (pos >= 0) {
                dictionary[pos]->freq++;
            } else {
                insert_word(dictionary, &word_count, token);
            }
        }

        fclose(file);
    }

    printf("Unique words: %d\n", word_count);

    /* --- Сортировка по алфавиту --- */
    qsort(dictionary, word_count, sizeof(Entry *), sort_alpha);

    FILE *f_alpha = fopen("alpha.txt", "w");
    if (f_alpha) {
        for (int i = 0; i < word_count; i++)
            fprintf(f_alpha, "%-25s %d\n",
                    dictionary[i]->text,
                    dictionary[i]->freq);
        fclose(f_alpha);
    }

    /* --- Сортировка по частоте --- */
    qsort(dictionary, word_count, sizeof(Entry *), sort_freq);

    FILE *f_freq = fopen("freq.txt", "w");
    if (f_freq) {
        for (int i = 0; i < word_count; i++)
            fprintf(f_freq, "%-25s %d\n",
                    dictionary[i]->text,
                    dictionary[i]->freq);
        fclose(f_freq);
    }

    /* --- Очистка памяти --- */
    for (int i = 0; i < word_count; i++) {
        free(dictionary[i]->text);
        free(dictionary[i]);
    }

    return 0;
}

/* ----------- Чтение слова ----------- */
char *read_token(FILE *fp)
{
    static char buffer[LIMIT_LEN];
    int c, len = 0;

    while ((c = fgetc(fp)) != EOF) {
        if (isalpha(c)) {
            buffer[len++] = tolower(c);

            while ((c = fgetc(fp)) != EOF && (isalnum(c))) {
                if (len < LIMIT_LEN - 1)
                    buffer[len++] = tolower(c);
            }

            buffer[len] = '\0';
            return buffer;
        }
    }
    return NULL;
}

/* ----------- Поиск ----------- */
int search_word(Entry **dict, int size, const char *word)
{
    for (int i = 0; i < size; i++) {
        if (strcmp(dict[i]->text, word) == 0)
            return i;
    }
    return -1;
}

/* ----------- Добавление ----------- */
void insert_word(Entry **dict, int *size, const char *word)
{
    if (*size >= LIMIT_WORDS) return;

    dict[*size] = malloc(sizeof(Entry));
    dict[*size]->text = malloc(strlen(word) + 1);

    strcpy(dict[*size]->text, word);
    dict[*size]->freq = 1;

    (*size)++;
}

/* ----------- Сортировки ----------- */
int sort_alpha(const void *a, const void *b)
{
    Entry *x = *(Entry **)a;
    Entry *y = *(Entry **)b;
    return strcmp(x->text, y->text);
}

int sort_freq(const void *a, const void *b)
{
    Entry *x = *(Entry **)a;
    Entry *y = *(Entry **)b;

    if (y->freq != x->freq)
        return y->freq - x->freq;

    return strcmp(x->text, y->text);
}
