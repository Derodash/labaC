#include <stdio.h>
#include <locale.h>

int main() {
    setlocale(LC_ALL, "Russian");
	int n, isPrime = 1;

    printf("횂창책채챔챵책 첨챔챰챘챤: ");
    scanf("%d", &n);

    if (n <= 1) {
        isPrime = 0;
    }
	int i;
    for (i = 2; i < n; i++) {
        if (n % i == 0) {
            isPrime = 0;
        }
    }

    if (isPrime) {
        printf("횕챨챤챰챵챤책 첨챔챰챘챤\n");
    } else {
        printf("횒책 챦챨챤챰챵챤책\n");
    }

    return 0;
}
